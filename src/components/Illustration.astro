---
// Original abstract geometric illustrations — vector only, theme-aware.
// Colors come from CSS custom properties (see :root in global.css), so they
// track the site palette automatically. Decorative, hence aria-hidden.
//
//   variant="hero"   -> square-ish composition for the home hero
//   variant="orbits" | "nodes" | "waves" | "grid" -> wide header banners
//
// Pick a banner deterministically from a string (e.g. a post slug):
export function variantFor(seed: string): 'orbits' | 'nodes' | 'waves' | 'grid' {
  const variants = ['orbits', 'nodes', 'waves', 'grid'] as const;
  let sum = 0;
  for (const ch of seed) sum += ch.charCodeAt(0);
  return variants[sum % variants.length];
}

interface Props {
  variant?: 'hero' | 'orbits' | 'nodes' | 'waves' | 'grid';
  class?: string;
}
const { variant = 'orbits', class: className = '' } = Astro.props;
const cls = `illus illus-${variant} ${className}`.trim();
---

{
  variant === 'hero' && (
    <svg class={cls} viewBox="0 0 440 380" fill="none" aria-hidden="true" role="presentation">
      <circle cx="248" cy="186" r="150" fill="var(--accent-pale)" opacity="0.55" />
      <circle cx="186" cy="172" r="124" stroke="var(--accent-soft)" stroke-width="1.5" opacity="0.55" />
      <circle cx="186" cy="172" r="82" stroke="var(--accent)" stroke-width="1.5" opacity="0.85" />
      <circle cx="186" cy="172" r="42" stroke="var(--accent-soft)" stroke-width="1.5" />
      <path d="M58 252 A150 150 0 0 1 306 70" stroke="var(--accent)" stroke-width="2" stroke-linecap="round" opacity="0.5" />
      <g stroke="var(--accent-deep)" stroke-width="1.2" opacity="0.45">
        <line x1="122" y1="118" x2="240" y2="190" />
        <line x1="240" y1="190" x2="182" y2="292" />
        <line x1="240" y1="190" x2="330" y2="150" />
        <line x1="122" y1="118" x2="92" y2="222" />
        <line x1="330" y1="150" x2="300" y2="250" />
      </g>
      <circle cx="122" cy="118" r="7" fill="var(--accent)" />
      <circle cx="240" cy="190" r="9.5" fill="var(--accent-deep)" />
      <circle cx="182" cy="292" r="6" fill="var(--accent-soft)" />
      <circle cx="330" cy="150" r="8" fill="var(--accent-2)" />
      <circle cx="92" cy="222" r="5" fill="var(--accent)" />
      <circle cx="300" cy="250" r="6.5" fill="var(--accent-soft)" />
      <g fill="var(--accent-soft)" opacity="0.85">
        <circle cx="356" cy="214" r="3" />
        <circle cx="150" cy="58" r="3" />
        <circle cx="78" cy="150" r="2.5" />
      </g>
    </svg>
  )
}

{
  variant === 'orbits' && (
    <svg class={cls} viewBox="0 0 720 200" fill="none" aria-hidden="true" role="presentation">
      <defs>
        <clipPath id="clip-orbits"><rect width="720" height="200" rx="14" /></clipPath>
      </defs>
      <g clip-path="url(#clip-orbits)">
        <rect width="720" height="200" rx="14" fill="var(--accent-pale)" opacity="0.4" />
        <circle cx="560" cy="100" r="150" stroke="var(--accent-soft)" stroke-width="1.5" opacity="0.5" />
        <circle cx="560" cy="100" r="100" stroke="var(--accent)" stroke-width="1.5" opacity="0.7" />
        <circle cx="560" cy="100" r="52" stroke="var(--accent-soft)" stroke-width="1.5" />
        <circle cx="560" cy="48" r="7" fill="var(--accent-2)" />
        <circle cx="660" cy="100" r="6" fill="var(--accent-deep)" />
        <circle cx="560" cy="100" r="9" fill="var(--accent)" />
        <g fill="var(--accent-soft)">
          <circle cx="120" cy="70" r="4" />
          <circle cx="180" cy="130" r="3" />
          <circle cx="80" cy="140" r="2.5" />
          <circle cx="250" cy="90" r="3.5" />
        </g>
        <line x1="120" y1="70" x2="250" y2="90" stroke="var(--accent)" stroke-width="1.2" opacity="0.45" />
        <line x1="180" y1="130" x2="250" y2="90" stroke="var(--accent)" stroke-width="1.2" opacity="0.45" />
      </g>
    </svg>
  )
}

{
  variant === 'nodes' && (
    <svg class={cls} viewBox="0 0 720 200" fill="none" aria-hidden="true" role="presentation">
      <defs>
        <clipPath id="clip-nodes"><rect width="720" height="200" rx="14" /></clipPath>
      </defs>
      <g clip-path="url(#clip-nodes)">
        <rect width="720" height="200" rx="14" fill="var(--accent-pale)" opacity="0.4" />
        <g stroke="var(--accent)" stroke-width="1.2" opacity="0.5">
          <line x1="90" y1="60" x2="220" y2="120" />
          <line x1="220" y1="120" x2="340" y2="70" />
          <line x1="340" y1="70" x2="470" y2="130" />
          <line x1="470" y1="130" x2="600" y2="80" />
          <line x1="600" y1="80" x2="660" y2="150" />
          <line x1="220" y1="120" x2="300" y2="160" />
          <line x1="340" y1="70" x2="300" y2="160" />
          <line x1="90" y1="60" x2="150" y2="150" />
        </g>
        <circle cx="90" cy="60" r="6" fill="var(--accent)" />
        <circle cx="220" cy="120" r="8" fill="var(--accent-deep)" />
        <circle cx="340" cy="70" r="6.5" fill="var(--accent-soft)" />
        <circle cx="470" cy="130" r="9" fill="var(--accent)" />
        <circle cx="600" cy="80" r="7" fill="var(--accent-2)" />
        <circle cx="660" cy="150" r="5" fill="var(--accent-soft)" />
        <circle cx="300" cy="160" r="5.5" fill="var(--accent-soft)" />
        <circle cx="150" cy="150" r="4" fill="var(--accent-soft)" />
      </g>
    </svg>
  )
}

{
  variant === 'waves' && (
    <svg class={cls} viewBox="0 0 720 200" fill="none" aria-hidden="true" role="presentation">
      <defs>
        <clipPath id="clip-waves"><rect width="720" height="200" rx="14" /></clipPath>
      </defs>
      <g clip-path="url(#clip-waves)">
        <rect width="720" height="200" rx="14" fill="var(--accent-pale)" opacity="0.4" />
        <path d="M-10 150 C 120 100 220 200 360 140 S 600 80 730 130" stroke="var(--accent-soft)" stroke-width="2" opacity="0.6" />
        <path d="M-10 120 C 130 70 230 170 360 110 S 610 50 730 100" stroke="var(--accent)" stroke-width="2" opacity="0.85" />
        <path d="M-10 90 C 140 40 240 140 360 80 S 620 20 730 70" stroke="var(--accent-deep)" stroke-width="1.5" opacity="0.5" />
        <circle cx="360" cy="110" r="6" fill="var(--accent-2)" />
        <circle cx="160" cy="92" r="4" fill="var(--accent)" />
        <circle cx="560" cy="84" r="4.5" fill="var(--accent-deep)" />
      </g>
    </svg>
  )
}

{
  variant === 'grid' && (
    <svg class={cls} viewBox="0 0 720 200" fill="none" aria-hidden="true" role="presentation">
      <defs>
        <clipPath id="clip-grid"><rect width="720" height="200" rx="14" /></clipPath>
      </defs>
      <g clip-path="url(#clip-grid)">
        <rect width="720" height="200" rx="14" fill="var(--accent-pale)" opacity="0.4" />
        <g fill="var(--accent-soft)">
          <circle cx="120" cy="50" r="2" /><circle cx="200" cy="50" r="2.5" /><circle cx="280" cy="50" r="3" /><circle cx="360" cy="50" r="3.5" /><circle cx="440" cy="50" r="3" /><circle cx="520" cy="50" r="2.5" /><circle cx="600" cy="50" r="2" />
          <circle cx="120" cy="100" r="2.5" /><circle cx="200" cy="100" r="3" /><circle cx="280" cy="100" r="4" /><circle cx="440" cy="100" r="4" /><circle cx="520" cy="100" r="3" /><circle cx="600" cy="100" r="2.5" />
          <circle cx="120" cy="150" r="2" /><circle cx="200" cy="150" r="2.5" /><circle cx="280" cy="150" r="3" /><circle cx="360" cy="150" r="3.5" /><circle cx="440" cy="150" r="3" /><circle cx="520" cy="150" r="2.5" /><circle cx="600" cy="150" r="2" />
        </g>
        <circle cx="360" cy="100" r="9" fill="var(--accent)" />
        <circle cx="360" cy="100" r="20" stroke="var(--accent)" stroke-width="1.5" opacity="0.5" />
        <circle cx="280" cy="100" r="4" fill="var(--accent-2)" />
      </g>
    </svg>
  )
}
